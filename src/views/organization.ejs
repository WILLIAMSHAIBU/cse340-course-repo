<%- include('partials/header') %>
<main>
    <h2><%= title %></h2>

    <h3><%= organizationDetails.name %></h3>

    <p>Description: <%= organizationDetails.description %></p>

    <p>Contact Email: <%= organizationDetails.contact_email %></p>

    <img src="/images/<%= organizationDetails.logo_filename %>" alt="<%= organizationDetails.name %> logo">

    <% if (projects && projects.length > 0) { %>
        <h3>Projects</h3>
        <ul>
            <% projects.forEach(project => { %>
                <li><a href="/project/<%= project.project_id %>"><%= project.title %></a></li>
            <% }) %>
        </ul>
    <% } else { %>
        <p>No projects yet.</p>
    <% } %>

    <p><a href="/edit-organization/<%= organizationDetails.organization_id %>">Edit Organization</a></p>
    <p><a href="/organizations">Back to all organizations</a></p>
</main>
<%- include('partials/footer') %>
