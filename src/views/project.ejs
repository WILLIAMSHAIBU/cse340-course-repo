<%- include('partials/header') %>
<main>
    <h2><%= title %></h2>

    <h3><%= projectDetails.title %></h3>

    <p>Description: <%= projectDetails.description %></p>

    <% if (projectDetails.location) { %>
        <p>Location: <%= projectDetails.location %></p>
    <% } %>

    <% if (projectDetails.project_date) { %>
        <p>Date: <%= new Date(projectDetails.project_date).toLocaleDateString() %></p>
    <% } %>

    <h3>Categories</h3>
    <ul>
        <% categories.forEach(category => { %>
            <li><a href="/category/<%= category.category_id %>"><%= category.name %></a></li>
        <% }) %>
    </ul>

    <p><a href="/projects">Back to all projects</a></p>
</main>
<%- include('partials/footer') %>
