<%- include('partials/header') %>
<main>
    <h2><%= title %></h2>

    <h3><%= categoryDetails.name %></h3>

    <h3>Projects</h3>
    <ul>
        <% projects.forEach(project => { %>
            <li><a href="/project/<%= project.project_id %>"><%= project.title %></a></li>
        <% }) %>
    </ul>

    <p><a href="/categories">Back to all categories</a></p>
</main>
<%- include('partials/footer') %>
